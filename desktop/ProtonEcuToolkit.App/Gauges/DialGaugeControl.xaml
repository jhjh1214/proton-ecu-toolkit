<UserControl x:Class="ProtonEcuToolkit.App.Gauges.DialGaugeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="190" Height="210">
    <Border Background="#161616" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Padding="8">
        <StackPanel>
            <Canvas x:Name="FaceCanvas" Width="170" Height="170" HorizontalAlignment="Center">
                <!-- outer bezel -->
                <Ellipse Width="170" Height="170" Canvas.Left="0" Canvas.Top="0">
                    <Ellipse.Fill>
                        <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                            <GradientStop Color="#3A3A3D" Offset="0.92" />
                            <GradientStop Color="#0E0E0F" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- gauge face -->
                <Ellipse Width="156" Height="156" Canvas.Left="7" Canvas.Top="7">
                    <Ellipse.Fill>
                        <RadialGradientBrush GradientOrigin="0.5,0.42" Center="0.5,0.42" RadiusX="0.8" RadiusY="0.8">
                            <GradientStop Color="#262626" Offset="0" />
                            <GradientStop Color="#0A0A0A" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Path x:Name="DangerArc" Stroke="#E53535" StrokeThickness="5" Fill="{x:Null}" />
                <Canvas x:Name="TicksCanvas" />
                <Polygon x:Name="Needle" Fill="#F2F2F2" />
                <Ellipse Width="16" Height="16" Canvas.Left="77" Canvas.Top="77"
                         Fill="#1A1A1A" Stroke="#555555" StrokeThickness="1" />
                <Ellipse Width="6" Height="6" Canvas.Left="82" Canvas.Top="82" Fill="#E53535" />
                <TextBlock x:Name="ValueText" FontSize="22" FontWeight="Bold" Foreground="White" />
                <TextBlock x:Name="UnitText" FontSize="10" Foreground="#999999" />
            </Canvas>
            <TextBlock Text="{Binding Name}" Foreground="#AAAAAA" FontSize="11" HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
        </StackPanel>
    </Border>
</UserControl>
