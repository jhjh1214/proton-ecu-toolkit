<UserControl x:Class="ProtonEcuToolkit.App.Gauges.DigitalGaugeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="190" Height="130">
    <Border Background="#0C0C0C" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Padding="12">
        <StackPanel>
            <TextBlock Text="{Binding Name}" Foreground="#888888" FontSize="10" FontWeight="SemiBold"
                       HorizontalAlignment="Left" Margin="0,0,0,6" />
            <Canvas x:Name="SegmentBarCanvas" Height="20" Width="166" HorizontalAlignment="Left" />
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock x:Name="ValueText" FontSize="36" FontWeight="Black" Foreground="White"
                           FontFamily="Consolas" />
                <TextBlock x:Name="UnitText" FontSize="13" Foreground="#888888" Margin="6,0,0,0"
                           VerticalAlignment="Bottom" Padding="0,0,0,4" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
