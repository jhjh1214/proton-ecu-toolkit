<UserControl x:Class="ProtonEcuToolkit.App.Gauges.DigitalGaugeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="170" Height="130">
    <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" Padding="10">
        <StackPanel>
            <TextBlock Text="{Binding Name}" Foreground="#AAAAAA" FontSize="11" HorizontalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,4">
                <TextBlock Text="{Binding DisplayText}" Foreground="{Binding ZoneBrush}"
                           FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Unit}" Foreground="#999999" FontSize="11"
                           Margin="4,6,0,0" VerticalAlignment="Bottom" />
            </StackPanel>
            <Grid Width="140" Height="32">
                <Polyline Points="{Binding SparklinePoints}" Stroke="{Binding ZoneBrush}" StrokeThickness="2" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
