<UserControl x:Class="ProtonEcuToolkit.App.Gauges.GaugeTileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ProtonEcuToolkit.App.Gauges">
    <UserControl.Resources>
        <DataTemplate x:Key="DialTemplate">
            <local:DialGaugeControl />
        </DataTemplate>
        <DataTemplate x:Key="DigitalTemplate">
            <local:DigitalGaugeControl />
        </DataTemplate>
        <local:ThemeToTemplateConverter x:Key="ThemeToTemplateConverter"
                                        DialTemplate="{StaticResource DialTemplate}"
                                        DigitalTemplate="{StaticResource DigitalTemplate}" />
    </UserControl.Resources>
    <Grid>
        <ContentControl Content="{Binding}"
                        ContentTemplate="{Binding Theme, Converter={StaticResource ThemeToTemplateConverter}}" />
        <Button Content="&#9881;" Width="20" Height="20" Padding="0" FontSize="11"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4"
                Background="#33000000" BorderThickness="0" Foreground="#CCCCCC"
                Click="OnGearClick" AutomationProperties.AutomationId="GearButton" />
        <Popup x:Name="EditorPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <local:GaugeEditorView />
        </Popup>
    </Grid>
</UserControl>
