<UserControl x:Class="ProtonEcuToolkit.App.Views.ScannerPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:scanning="clr-namespace:ProtonEcuToolkit.App.Scanning"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=scanning:ScannerViewModel}">
    <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEEE" Margin="0,0,0,6">
            PID/CID scanner - Service 0x22 (ReadDataByCommonIdentifier) reads only
        </TextBlock>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Known candidates" Padding="8,2" Margin="0,0,4,0"
                    Command="{Binding SetRangeCommand}"
                    CommandParameter="{x:Static scanning:ScanRangeOption.KnownCandidates}" />
            <Button Content="Nearby range" Padding="8,2" Margin="0,0,4,0"
                    Command="{Binding SetRangeCommand}"
                    CommandParameter="{x:Static scanning:ScanRangeOption.NearbyRange}" />
            <Button Content="Wide range" Padding="8,2" Margin="0,0,12,0"
                    Command="{Binding SetRangeCommand}"
                    CommandParameter="{x:Static scanning:ScanRangeOption.WideRange}" />
            <TextBlock Text="{Binding RangeDescription}" Foreground="#999999" VerticalAlignment="Center"
                       Margin="0,0,16,0" />
            <Button Content="Start scan" Padding="8,2" Margin="0,0,8,0" Command="{Binding StartScanCommand}" />
            <Button Content="Stop" Padding="8,2" Margin="0,0,8,0" Command="{Binding StopScanCommand}" />
            <Button Content="Export hits to CSV" Padding="8,2" Command="{Binding ExportCsvCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <ProgressBar Minimum="0" Maximum="{Binding TotalCount}" Value="{Binding ScannedCount}"
                         Height="16" Margin="0,0,0,4" />
            <TextBlock Foreground="#CCCCCC" FontSize="11">
                <Run Text="{Binding ScannedCount, Mode=OneWay}" />
                <Run Text="/" />
                <Run Text="{Binding TotalCount, Mode=OneWay}" />
                <Run Text=" scanned -- positive: " />
                <Run Text="{Binding Hits.Count, Mode=OneWay}" Foreground="#4CAF50" />
                <Run Text=" negative: " />
                <Run Text="{Binding NegativeCount, Mode=OneWay}" />
                <Run Text=" no response: " />
                <Run Text="{Binding NoResponseCount, Mode=OneWay}" />
                <Run Text=" malformed: " />
                <Run Text="{Binding MalformedCount, Mode=OneWay}" />
            </TextBlock>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#999999" FontSize="11" Margin="0,4,0,0" />
            <TextBlock Text="{Binding LastLogFilePath, StringFormat='Full evidence log: {0}'}" Foreground="#666666"
                       FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Hits}" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#0C0C0C" Foreground="#EEEEEE" RowBackground="#161616" AlternatingRowBackground="#1B1B1B"
                  BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2A2A2A"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Identifier" Binding="{Binding IdentifierHex}" Width="80" />
                <DataGridTextColumn Header="Request" Binding="{Binding RequestHex}" Width="100" />
                <DataGridTextColumn Header="Response" Binding="{Binding ResponseHex}" Width="160" />
                <DataGridTextColumn Header="Latency (ms)" Binding="{Binding LatencyMs}" Width="90" />
                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}"
                                     Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
