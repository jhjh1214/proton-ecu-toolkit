<UserControl x:Class="ProtonEcuToolkit.App.Views.ConnectionPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
        <ComboBox Width="220" ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPort}" Margin="0,0,8,0"
                  AutomationProperties.AutomationId="PortComboBox" />
        <Button Content="Refresh" Command="{Binding RefreshPortsCommand}" Margin="0,0,8,0" Padding="8,2"
                AutomationProperties.AutomationId="RefreshButton" />
        <Button Content="Connect" Command="{Binding ConnectCommand}" Margin="0,0,8,0" Padding="8,2"
                AutomationProperties.AutomationId="ConnectButton" />
        <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Margin="0,0,8,0" Padding="8,2"
                AutomationProperties.AutomationId="DisconnectButton" />
        <TextBlock x:Name="StatusTextBlock" Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="#EEEEEE"
                   AutomationProperties.AutomationId="StatusText" />
    </StackPanel>
</UserControl>
