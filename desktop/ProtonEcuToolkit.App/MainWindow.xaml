<Window x:Class="ProtonEcuToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ProtonEcuToolkit.App.Views"
        xmlns:vm="clr-namespace:ProtonEcuToolkit.App.ViewModels"
        Title="Proton ECU Toolkit" Height="700" Width="900"
        Background="#111111">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <ScrollViewer Margin="16" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Proton ECU Toolkit" FontSize="18" FontWeight="Bold" Foreground="#EEEEEE"
                       Margin="0,0,0,12" />
            <views:ConnectionPanelView />
            <views:GaugePanelView />
            <views:DtcPanelView />
            <TextBlock Text="Log" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEEE" Margin="0,0,0,4" />
            <ListBox ItemsSource="{Binding LogLines}" Height="160" Background="#000000" Foreground="#99FF99"
                     FontFamily="Consolas" FontSize="11" BorderThickness="0" />
        </StackPanel>
    </ScrollViewer>
</Window>
